{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "dev-secret-change-me-please-32-bytes",
    "Issuer": "goodstuff-user-api",
    "Audience": "goodstuff"
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "product-by-type": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/gateway/product/{type}",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/Product/{type}"
          }
        ]
      },
      "product-filters": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/gateway/product/{type}/filters",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/Product/{type}/filters"
          }
        ]
      },
      "user-signin": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/gateway/user/signin",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/user/signin"
          }
        ]
      },
      "user-me": {
        "ClusterId": "user-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/gateway/user/me",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/user/me"
          }
        ]
      },
      "user-signout": {
        "ClusterId": "user-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/gateway/user/signout",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/user/signout"
          }
        ]
      },
      "cart-create": {
        "ClusterId": "cart-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/gateway/cart",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/cart"
          }
        ]
      },
      "cart-get": {
        "ClusterId": "cart-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/gateway/cart",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/cart"
          }
        ]
      }
    },
    "Clusters": {
      "product-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://product-api:8080"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://user-api:8080"
          }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://cart-api:8080"
          }
        }
      }
    }
  }
}
